{
  "expo": {
    "name": "ScanMe",
    "slug": "ScanMe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/mascot.png",
    "scheme": "scanMe",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E1EEF6",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.ScanMe"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/mascot.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/mascot.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#E1EEF6",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      "expo-font",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
